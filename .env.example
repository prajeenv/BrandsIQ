# ===========================================
# BrandsIQ Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control!

# ===========================================
# Database (Supabase PostgreSQL)
# ===========================================
# Get from: Supabase Dashboard > Settings > Database > Connection string
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# ===========================================
# NextAuth.js
# ===========================================
NEXTAUTH_URL="http://localhost:3000"
# Generate with: openssl rand -base64 32
# Or visit: https://generate-secret.vercel.app/32
NEXTAUTH_SECRET="your-secret-key-here"

# ===========================================
# Google OAuth (Optional for MVP)
# ===========================================
# Get from: Google Cloud Console > APIs & Services > Credentials
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ===========================================
# AI Services
# ===========================================
# Anthropic Claude API (for response generation)
# Get from: console.anthropic.com
ANTHROPIC_API_KEY="sk-ant-api03-..."

# DeepSeek API (for sentiment analysis)
# Get from: platform.deepseek.com
DEEPSEEK_API_KEY="sk-..."

# ===========================================
# Email Service (Resend)
# ===========================================
# Get from: resend.com/api-keys
RESEND_API_KEY="re_..."
# Email address for sending (must be verified in Resend)
EMAIL_FROM="BrandsIQ <noreply@brandsiq.app>"

# ===========================================
# Rate Limiting (Upstash Redis)
# ===========================================
# Get from: console.upstash.com
UPSTASH_REDIS_REST_URL="https://your-db.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-token-here"

# ===========================================
# Application
# ===========================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Set to "production" in production
NODE_ENV="development"

# ===========================================
# Analytics (PostHog)
# ===========================================
# Get from: PostHog > Settings > Project > Project API Key
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN="phc_..."
NEXT_PUBLIC_POSTHOG_HOST="https://eu.i.posthog.com"

# ===========================================
# Sentry Error Tracking (Production only)
# ===========================================
# Get from: Sentry > Settings > Projects > [project] > Client Keys (DSN)
# Both should be the same DSN value from your Sentry EU project
# Leave blank in development - SDK is gated off when NODE_ENV !== "production"
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_DSN=""

# ===========================================
# Cron Jobs (Vercel)
# ===========================================
# Secret for authenticating cron job requests
# Generate with: openssl rand -base64 32
# Add to Vercel environment variables for production
# In development, leave unset to allow unauthenticated access for testing
CRON_SECRET="your-cron-secret-here"

# ===========================================
# Integrations (external server-to-server API key)
# ===========================================
# Bearer secret for POST /api/integrations/generate-response, used by the
# One-Pager Mailer Google Apps Script to generate a review response from raw
# text (no user account, no credits). See
# docs/MVP_Phase-1/ONE_PAGER_MAILER_DESIGN.md Section 10.
# Generate with: openssl rand -base64 32
# Separate from CRON_SECRET (independent rotation + blast radius).
# Must be REQUIRED in every environment (no dev bypass) — the endpoint spends
# Claude tokens. The SAME value must be stored in the Apps Script's Script
# Properties under INTEGRATIONS_API_KEY.
INTEGRATIONS_API_KEY="your-integrations-api-key-here"

# ===========================================
# MVP Phase 1: Closed Beta
# See docs/MVP_Phase-1/MVP.md
# ===========================================
# Comma-separated list of emails that can access /dashboard/admin/*
# and /api/admin/*. Non-founders get 404 (no route disclosure).
# Read by src/lib/auth-helpers.ts:isFounder().
FOUNDER_EMAILS="prajeen.builder@gmail.com"

# Phase flag: "phase_1" (closed beta, default) or "phase_2" (commercial launch).
# In phase_1, beta invite links work and the pricing page shows the closed-beta
# banner. In phase_2, invite codes are ignored at signup and pricing flips to
# the live tier-selection UI. Read by src/lib/system-phase.ts:getCurrentPhase().
CURRENT_PHASE="phase_1"
